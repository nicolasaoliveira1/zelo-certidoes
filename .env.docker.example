# Exemplo de variaveis para o docker-compose (spec 06). SEM segredos reais.
# Uso: copie para .env.docker (gitignored) e ajuste; depois:
#   docker compose --env-file .env.docker up
# Nada aqui deve conter senha de producao — e ambiente de DEV local.

# Chave da app (troque por qualquer valor de dev).
SECRET_KEY=troque_esta_chave_de_dev

# MySQL de dev (o compose sobe o container com estes valores).
MYSQL_ROOT_PASSWORD=dev_root_pwd
MYSQL_DATABASE=sistema_certidoes
